{
  "name": "@noteship/infra",
  "private": true,
  "version": "0.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "synth": "cross-env NODE_OPTIONS=--env-file=../../.env cdk synth",
    "bootstrap": "cdk bootstrap",
    "deploy:dev": "cross-env NODE_OPTIONS=--env-file=../../.env cdk deploy -c env=dev -c region=us-east-1"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.151.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
