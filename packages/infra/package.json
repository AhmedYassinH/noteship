{
  "name": "@noteship/infra",
  "private": true,
  "version": "0.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "synth": "dotenv -e ../../.env -- cdk synth",
    "bootstrap": "dotenv -e ../../.env -- cdk bootstrap --no-app",
    "deploy:dev": "dotenv -e ../../.env -- cdk deploy -c env=dev -c region=us-east-1",
    "deploy:core:dev": "dotenv -e ../../.env -- cdk deploy NoteshipCore-dev -c env=dev -c region=us-east-1 --profile noteship-dev",
    "deploy:api:dev": "dotenv -e ../../.env -- cdk deploy NoteshipApi-dev -c env=dev -c region=us-east-1 --profile noteship-dev"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.151.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.16.5",
    "aws-sdk": "^2.1693.0",
    "dotenv-cli": "^7.4.2",
    "esbuild": "^0.25.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
