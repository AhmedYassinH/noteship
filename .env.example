# Web (apps/web)
NEXT_PUBLIC_API_BASE_URL=https://api.noteship.local
NEXT_PUBLIC_ENV=dev
# Auth0 domain without scheme (no https://)
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=
NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_AUTH0_LOGOUT_REDIRECT_URI=http://localhost:3000
NEXT_PUBLIC_CONTENT_DOMAIN=content.noteship.local

# API + Workers (apps/api, apps/workers)
AWS_REGION=us-east-1
NOTESHIP_CONTENT_BUCKET_NAME=noteship-content-dev
NOTESHIP_USERS_TABLE_NAME=noteship-users-dev
NOTESHIP_NOTES_TABLE_NAME=noteship-notes-dev
NOTESHIP_POSTS_TABLE_NAME=noteship-posts-dev
NOTESHIP_INTEGRATIONS_TABLE_NAME=noteship-integrations-dev
NOTESHIP_USAGE_TABLE_NAME=noteship-usage-dev
NOTESHIP_JOBS_TABLE_NAME=noteship-jobs-dev
NOTESHIP_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/noteship-jobs-dev
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com/
AUTH0_AUDIENCE=
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_DRAFT_MODEL=gpt-4o-mini
QDRANT_URL=
QDRANT_COLLECTION=noteship-dev
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MEDIUM_CLIENT_ID=
MEDIUM_CLIENT_SECRET=
# Comma-separated exact origins for credentialed CORS
NOTESHIP_WEB_ORIGIN=https://noteship.local,http://localhost:3000,http://127.0.0.1:3000
# Comma-separated origins allowed to upload directly to S3 presigned URLs
NOTESHIP_CONTENT_UPLOAD_ORIGIN=https://noteship.local,http://localhost:3000,http://127.0.0.1:3000
# API custom domain + certificate (ACM in us-east-1)
NOTESHIP_API_CUSTOM_DOMAIN=api.noteship.local
NOTESHIP_API_CERTIFICATE_ARN=arn:aws:acm:us-east-1:423423422342:certificate/YOUR-API-CERT-ID
# Content custom domain + certificate (ACM in us-east-1)
NOTESHIP_CONTENT_CUSTOM_DOMAIN=content.noteship.local
NOTESHIP_CONTENT_CERTIFICATE_ARN=arn:aws:acm:us-east-1:423423422342:certificate/YOUR-CONTENT-CERT-ID
# Optional cookie domain. Keep empty for host-only cookie scope.
# Do not include protocol or port.
NOTESHIP_CONTENT_COOKIE_DOMAIN=noteship.local
# Optional content session TTL in seconds (default 43200 = 12 hours)
NOTESHIP_CONTENT_SESSION_TTL_SECONDS=43200
NOTESHIP_CLOUDFRONT_KEY_PAIR_ID=
# Provide raw PEM or base64-encoded PEM (supports \n escapes)
NOTESHIP_CLOUDFRONT_PRIVATE_KEY=

# Optional runtime overrides
NOTESHIP_LLM_PROVIDER=openai
NOTESHIP_VECTOR_DB_PROVIDER=qdrant
QDRANT_API_KEY=

# Operational observability + cost guardrails (packages/infra)
NOTESHIP_GUARDRAILS_BUDGET_LIMIT_USD=25
NOTESHIP_GUARDRAILS_BILLING_ALARM_USD=15
NOTESHIP_GUARDRAILS_EMAILS=
NOTESHIP_HTTP_API_ID=

# Cloudfront custom domain
NOTESHIP_WEB_DOMAIN=noteship.com
NOTESHIP_WEB_CERTIFICATE_ARN=arn:aws:acm:us-east-1:423423422342:certificate/YOUR-CERT-ID



# Role for CI/CD 
AWS_ROLE_ARN=arn:aws:iam::34r2432423:role/Noteship-CICD
