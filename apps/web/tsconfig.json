{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@noteship/domain": ["../../packages/domain/src"],
      "@noteship/utils": ["../../packages/utils/src"],
      "@ui/*": ["components/ui/*"],
      "@features/*": ["components/features/*"],
      "@data/*": ["data/*"]
    },
    "allowJs": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
